</script><div style="margin-top:.5rem;font-size:.78rem;color:#888;text-align:center">View larger map</div></div></section><footer style="background:#0A0A0A;color:rgba(255,255,255,.85);padding:3rem 1.5rem 2rem"><div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:2rem"><div><h4 style="color:#FFF;font-size:1rem;margin:0 0 .8rem">GEOTECHNICAL ENGINEERING</h4><p style="margin:0;font-size:.9rem;color:rgba(255,255,255,.7);line-height:1.6">Overland Park, USA</p></div><div><h4 style="color:#FFF;font-size:.92rem;margin:0 0 .8rem">SERVICES</h4><a href="/" style="color:rgba(255,255,255,.75);text-decoration:none;display:block;padding:.25rem 0">Services</a></div><div><h4 style="color:#FFF;font-size:.92rem;margin:0 0 .8rem">CONTACT</h4><p style="margin:0;font-size:.9rem;line-height:1.8"><a href="mailto:contact@geotechnical-engineering.xyz" style="color:#FFF;text-decoration:none">contact@geotechnical-engineering.xyz</a></p></div></div><div style="max-width:1100px;margin:2rem auto 0;padding-top:1.2rem;border-top:1px solid rgba(255,255,255,.1);text-align:center;font-size:.8rem;color:rgba(255,255,255,.5)">© 2026 Geotechnical Engineering. All rights reserved.</div><div data-authority-refs class="authority-refs" style="text-align:center;font-size:.8rem;padding:.5rem 0;opacity:.6"><strong>References:</strong>ASTM Standards · USACE Engineer Manuals · ISO Geotechnical</div><div class="updated-info" data-updated="2026-04-10" style="text-align:center;font-size:.85rem;opacity:.7;padding:.5rem 0">Last updated: 2026-04-10</div></footer><script id="sidebar-toggle-v3">
(function(){
if(window.__sidebarToggleV3){return}window.__sidebarToggleV3=true;
// Event delegation en document — funciona aunque DOMContentLoaded ya haya pasado.
// Ver REGLA 34 #7 (JS race conditions) y avance53.
document.addEventListener('click',function(e){
var btn=e.target.closest&&e.target.closest('.cat-toggle');
if(!btn)return;
e.preventDefault();
var item=btn.closest('.cat-item');
if(!item)return;
var sub=item.querySelector('.cat-sub');
var open=btn.getAttribute('aria-expanded')==='true';
btn.setAttribute('aria-expanded',open?'false':'true');
if(sub){if(open){sub.setAttribute('hidden','')}else{sub.removeAttribute('hidden')}}
});
})();
</script></body></html>